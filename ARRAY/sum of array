#include <stdio.h>

int main() {
    int arr[100];
    int n, sum = 0;

    printf("Enter the number of elements into array:\n");
    scanf("%d", &n);

    printf("Enter the elements into array:\n");
    for (int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
        sum = sum + arr[i];
    }

    printf("Sum of array elements = %d", sum);

    return 0;
}
